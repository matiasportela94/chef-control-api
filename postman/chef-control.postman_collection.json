{
  "info": {
    "name": "Chef Control API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (nuevo restaurante)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantName\": \"El Rancho\",\n  \"ownerName\": \"Matias Portela\",\n  \"ownerEmail\": \"matias@elrancho.com\",\n  \"ownerPassword\": \"password123\",\n  \"ownerPhone\": \"+5491155551234\",\n  \"timezone\": \"America/Argentina/Buenos_Aires\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  const res = pm.response.json();",
                "  pm.environment.set('token', res.token);",
                "  pm.environment.set('restaurantId', res.activeRestaurantId);",
                "  pm.environment.set('userId', res.userId);",
                "  console.log('Registered. Token saved.');",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"matias@elrancho.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  const res = pm.response.json();",
                "  pm.environment.set('token', res.token);",
                "  pm.environment.set('restaurantId', res.activeRestaurantId);",
                "  pm.environment.set('userId', res.userId);",
                "  console.log('Logged in. Token saved.');",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Switch Restaurant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/switch-restaurant", "host": ["{{baseUrl}}"], "path": ["auth", "switch-restaurant"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantId\": \"{{restaurantId}}\"\n}"
            }
